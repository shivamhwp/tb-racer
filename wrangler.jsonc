{
  "name": "tb-racer",
  "main": "worker.js",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "durable_objects": {
    "bindings": [{ "name": "ROOMS", "class_name": "RaceRoom" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["RaceRoom"] }],
  "observability": { "enabled": true }
}
